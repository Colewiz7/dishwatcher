# dishwatcher camera config

DISH_SERVER_URL=http://YOUR_SERVER_IP:8000/upload
DISH_API_KEY=changeme
CAMERA_INDEX=0

# capture
FRAME_WIDTH=640
FRAME_HEIGHT=480
JPEG_QUALITY=60

# motion detection
MOTION_WIDTH=320
MOTION_HEIGHT=240
PROCESS_EVERY_N=3
IDLE_SLEEP_MS=50

# blame clips
VIDEO_FPS=5
VIDEO_DURATION=15
CAPTURE_DELAY_SEC=10

# heartbeat
HEARTBEAT_INTERVAL_SEC=30
MONITORING_DURATION_SEC=7200
CLEAR_EXIT_COUNT=3
