# dishwatcher edge config
# copy to .env and fill in your server address

DISH_SERVER_URL=http://YOUR_SERVER_IP:8000/upload
DISH_API_KEY=changeme
CAMERA_INDEX=0

# tweak if your pi is struggling
FRAME_WIDTH=640
FRAME_HEIGHT=480
MOTION_WIDTH=320
MOTION_HEIGHT=240
PROCESS_EVERY_N=3
IDLE_SLEEP_MS=50

# heartbeat
HEARTBEAT_INTERVAL_SEC=30
MONITORING_DURATION_SEC=7200
CLEAR_EXIT_COUNT=3
